# Port on which the FleetMaster backend server will run (Default: 5000)
PORT=5000

# Environment state (development, production)
NODE_ENV=development

# Allowed client origin URL for CORS (Default: http://localhost:5173)
CLIENT_URL=http://localhost:5173

# Maximum payload size for JSON requests (Default: 10mb)
JSON_LIMIT=10mb

# MongoDB connection string (Required)
MONGO_URI=mongodb://localhost:27017/fleetmaster

# JSON Web Token (JWT) Secrets
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# ImageKit Configurations (Required for vehicle/driver image upload features)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint_here

# DB Seeding Configurations (Optional)
# Used by seed.js to set up the system administrator
SEED_ADMIN_EMAIL=admin@fleetmaster.com
SEED_ADMIN_PASSWORD=your_secure_admin_password_here # Make sure it is >= 6 Characters long

# Default password assigned to seeded driver profiles by seeder.js
SEED_USER_PASSWORD=Fleet@123
